# Base URL of the Cloud Tasks worker, e.g. http://localhost:8787 or
# https://<your-api-domain>
WORKER_URL=http://localhost:8787

# API key configured on the worker (see packages/worker/.dev.vars.example)
API_KEY=replace-with-your-api-key

# Optional: auto-refresh interval in seconds (default: 5)
REFRESH_INTERVAL=5
