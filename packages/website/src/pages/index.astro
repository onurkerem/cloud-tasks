</Layout>

<script is:inline define:vars={{ installPrompt, connectCommand }}>
  const setupCopy = (btn, text, resetLabel) => {
    if (!btn) return;
    btn.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(text);
      } catch {
        const ta = document.createElement("textarea");
        ta.value = text;
        document.body.appendChild(ta);
        ta.select();
        document.execCommand("copy");
        document.body.removeChild(ta);
      }
      const icon = btn.querySelector(".copy-icon");
      const label = btn.querySelector(".copy-label");
      if (icon) icon.textContent = "check";
      if (label) label.textContent = "Copied";
      setTimeout(() => {
        if (icon) icon.textContent = "content_copy";
        if (label) label.textContent = resetLabel;
      }, 2000);
    });
  };
  setupCopy(document.getElementById("hero-copy-btn"), installPrompt, "Copy prompt");
  setupCopy(document.getElementById("connect-copy-btn"), connectCommand, "Copy");
</script>
